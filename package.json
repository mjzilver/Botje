{
  "name": "botje",
  "version": "3.0.0",
  "description": "Versatile & fun Discord bot.",
  "main": "dist/start.js",
  "author": "Mick Jari",
  "email": "4ilverj@gmail.com",
  "license": "GPL 3.0",
  "repository": "https://github.com/mjzilver/botje",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r src/json dist/json",
    "start": "npm run build && node dist/start.js",
    "dev": "ts-node-dev --respawn --transpile-only src/start.ts",
    "beta": "ts-node-dev --respawn --transpile-only src/start.ts --beta",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check src && eslint src",
    "lint-fix": "prettier --write src && eslint --fix src"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "compromise": "^14.15.1",
    "discord.js": "^14.25.1",
    "jimp": "^0.22.12",
    "pg": "^8.12.0",
    "pg-format": "^1.0.4",
    "sentiment": "^5.0.2",
    "winston": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/pg-format": "^1.0.5",
    "@types/sentiment": "^5.0.4",
    "@vitest/coverage-v8": "^2.0.0",
    "escomplex": "^2.0.0-alpha",
    "eslint": "^10.4.0",
    "esprima": "^4.0.1",
    "jscpd": "^4.2.4",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.0",
    "typhonjs-escomplex": "^0.1.0",
    "vitest": "^2.0.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
